# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@localhost:5432/0g_compute

# Session secret for Express (required)
SESSION_SECRET=change-me-to-a-random-secret

# API server port — set when running locally, not needed on Vercel
# PORT=5000

# 0G Network — defaults to testnet if not set
ZG_RPC_URL=https://evmrpc-testnet.0g.ai
ZG_SERVICE_URL=https://indexer-storage-testnet-standard.0g.ai
ZG_PRIVATE_KEY=0x...your_wallet_private_key

# Optional: external LLM provider key
# Format: provider=apikey  e.g. groq=gsk_...  or  0g=your-api-key
LLM_API_KEY=
